{
  "kind": "collectionType",
  "collectionName": "subscription_plans",
  "info": {
    "singularName": "subscription-plan",
    "pluralName": "subscription-plans",
    "displayName": "subscription-plan"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "currency": {
      "type": "string",
      "default": "USD",
      "required": true
    },
    "billingPeriod": {
      "type": "enumeration",
      "required": true,
      "default": "monthly",
      "enum": [
        "monthly",
        "yearly",
        "lifetime"
      ]
    },
    "description": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "isRecommended": {
      "type": "boolean",
      "default": false
    },
    "isPopular": {
      "type": "boolean",
      "default": false
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "maxRegisters": {
      "type": "integer",
      "default": 1
    },
    "isUnlimitedRegisters": {
      "type": "boolean",
      "default": false
    },
    "maxProducts": {
      "type": "integer",
      "default": 100
    },
    "isUnlimitedProducts": {
      "type": "boolean",
      "default": false
    },
    "stripeProductId": {
      "type": "string"
    },
    "stripePriceId": {
      "type": "string"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "features": {
      "type": "component",
      "component": "plan-features.plan-features",
      "repeatable": true
    },
    "planType": {
      "type": "enumeration",
      "enum": [
        "Starter",
        "Professional",
        "Enterprise"
      ]
    },
    "allowCustomerApp": {
      "type": "boolean",
      "default": false,
      "description": "Enable customer-facing mobile app for this plan"
    },
    "allowMenuBrowsing": {
      "type": "boolean",
      "default": false,
      "description": "Allow customers to browse menu/categories (restaurant/cafe)"
    },
    "allowBarcodeScanning": {
      "type": "boolean",
      "default": false,
      "description": "Allow customers to scan barcodes for product info (retail/pharmacy)"
    },
    "allowCustomerOrdering": {
      "type": "boolean",
      "default": false,
      "description": "Allow customers to place orders directly from mobile app"
    },
    "maxCustomerConnectionsPerSeat": {
      "type": "integer",
      "default": 50,
      "min": 1,
      "max": 500,
      "description": "Maximum concurrent customer connections per seat"
    }
  }
}
