{
  "kind": "collectionType",
  "collectionName": "key_seats",
  "info": {
    "singularName": "key-seat",
    "pluralName": "key-seats",
    "displayName": "Key-Seat",
    "description": "POS seat with activation and real-time telemetry data"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "machineUUID": {
      "type": "string"
    },
    "userSocketId": {
      "type": "string"
    },
    "telemetry": {
      "type": "json",
      "description": "Initial activation telemetry data (preserved from first connection)"
    },
    "realtimeTelemetry": {
      "type": "json",
      "description": "Real-time telemetry updates including business data (lastOrder, kpiSummary, expenses)"
    },
    "isActive": {
      "type": "boolean",
      "default": false
    },
    "license": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::license.license",
      "inversedBy": "seats"
    },
    "telemetryHistory": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::seat-telemetry-history.seat-telemetry-history",
      "mappedBy": "keySeat"
    }
  }
}
