{
  "kind": "collectionType",
  "collectionName": "key_seats",
  "info": {
    "singularName": "key-seat",
    "pluralName": "key-seats",
    "displayName": "Key-Seat",
    "description": "POS seat with activation and real-time telemetry data"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "machineUUID": {
      "type": "string"
    },
    "userSocketId": {
      "type": "string"
    },
    "telemetry": {
      "type": "json"
    },
    "isActive": {
      "type": "boolean",
      "default": false
    },
    "license": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::license.license",
      "inversedBy": "seats"
    },
    "telemetryHistory": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::seat-telemetry-history.seat-telemetry-history",
      "mappedBy": "keySeat"
    },
    "isConnected": {
      "type": "boolean"
    },
    "timezone": {
      "type": "string",
      "default": "UTC",
      "required": false
    },
    "realtimeTelemetry": {
      "type": "component",
      "component": "telemetry.realtime-telemetry",
      "repeatable": false
    },
    "historicalKpiSummary": {
      "type": "component",
      "component": "telemetry.historical-kpi-summary",
      "repeatable": false
    },
    "publicSeatId": {
      "type": "string",
      "unique": true,
      "required": false
    },
    "businessName": {
      "type": "string",
      "required": false
    },
    "businessType": {
      "type": "enumeration",
      "enum": ["restaurant", "retail", "cafe", "pharmacy", "other"],
      "default": "retail"
    },
    "allowCustomerApp": {
      "type": "boolean",
      "default": false
    },
    "allowMenuBrowsing": {
      "type": "boolean",
      "default": false
    },
    "allowBarcodeScanning": {
      "type": "boolean",
      "default": false
    },
    "allowCustomerOrdering": {
      "type": "boolean",
      "default": false
    },
    "maxCustomerConnections": {
      "type": "integer",
      "default": 50
    },
    "currentCustomerConnections": {
      "type": "integer",
      "default": 0
    },
    "customerFcmTokens": {
      "type": "component",
      "component": "user.fcm-token",
      "repeatable": true
    }
  }
}
