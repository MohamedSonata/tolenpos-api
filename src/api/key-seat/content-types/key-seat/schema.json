{
  "kind": "collectionType",
  "collectionName": "key_seats",
  "info": {
    "singularName": "key-seat",
    "pluralName": "key-seats",
    "displayName": "Key-Seat",
    "description": "POS seat with activation and real-time telemetry data"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "machineUUID": {
      "type": "string"
    },
    "userSocketId": {
      "type": "string"
    },
    "telemetry": {
      "type": "json"
    },
    "isActive": {
      "type": "boolean",
      "default": false
    },
    "license": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::license.license",
      "inversedBy": "seats"
    },
    "telemetryHistory": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::seat-telemetry-history.seat-telemetry-history",
      "mappedBy": "keySeat"
    },
    "isConnected": {
      "type": "boolean"
    },
    "timezone": {
      "type": "string",
      "default": "UTC",
      "required": false
    },
    "realtimeTelemetry": {
      "type": "component",
      "component": "telemetry.realtime-telemetry",
      "repeatable": false
    },
    "historicalKpiSummary": {
      "type": "component",
      "component": "telemetry.historical-kpi-summary",
      "repeatable": false
    }
  }
}
