# Database Configuration (PostgreSQL for production)
DATABASE_CLIENT=postgres
DATABASE_HOST=tolenPosDb
DATABASE_PORT=5432
DATABASE_NAME=tolen_pos_db
DATABASE_USERNAME=tolenpos
DATABASE_PASSWORD=Addingit
DATABASE_SSL=false

# Redis Configuration (for Socket.IO multi-replica support)
REDIS_URL=redis://redis:6371
ENABLE_REDIS_ADAPTER=true

MAILGUN_DOMAIN=Adding it
MAILGUN_APIKEY=Adding it
SOCKET_CORS_ORIGIN=http://localhost:1334

# Telemetry Configuration
# Retention period for telemetry snapshots (in days)
TELEMETRY_RETENTION_DAYS=90

# Timezone for cron jobs - ALWAYS USE UTC FOR INTERNATIONAL APPS
TZ=UTC

# Cron schedule for timezone-aware daily snapshot creation
# Format: minute hour day month weekday
# Production: "55 * * * *" = every hour at :55 minutes (checks all seat timezones)
# For testing: "*/1 * * * *" = every minute
TELEMETRY_SNAPSHOT_SCHEDULE=55 * * * *

# Cron schedule for cleanup job (default: 3 AM UTC every Sunday)
TELEMETRY_CLEANUP_SCHEDULE=0 3 * * 0

# Timeout for real-time telemetry queries (in milliseconds)
TELEMETRY_QUERY_TIMEOUT=10000